# Phase 1
forge:
	@echo "🔥 Forging $(ROOM)..."
	@mkdir -p forge/active/$(ROOM)
	@mkdir -p forge/versions/$(ROOM)
	@echo "   Workspace ready at forge/active/$(ROOM)"

lock:
	@echo "🔒 Locking $(ROOM) version $(V)..."
	@python3 tools/flow_lock.py lock $(ROOM) $(V)

verify:
	@echo "🔍 Verifying $(ROOM) lock..."
	@python3 tools/flow_lock.py verify $(ROOM)

# Phase 2
split:
	@echo "✂️  Splitting $(ROOM) into modules..."
	@python3 tools/flow_split.py $(ROOM)

# Phase 3
sort:
	@echo "📁 Sorting $(ROOM) into Unix structure..."
	@python3 tools/flow_sort.py $(ROOM)

# Phase 4
integrate:
	@echo "⚙️  Integrating $(ROOM) into C++ mesh..."
	@mkdir -p integration/$(ROOM)/{src,include,tests}

build:
	@echo "🔨 Building sovereign mesh..."
	@mkdir -p build
	@cd build && cmake .. && make
	@echo "✅ Mesh compiled. Sovereign."

test:
	@echo "🧪 Running sovereign tests..."
	@cd build && ctest --output-on-failure

clean:
	@echo "🧹 Cleaning..."
	@rm -rf build/
	@find . -name "__pycache__" -exec rm -rf {} + 2>/dev/null || true
	@echo "✅ Clean."
