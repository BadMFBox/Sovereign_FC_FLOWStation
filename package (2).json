// ═══════════════════════════════════════════════════════════════
//  package.json — TypeScript project config
// ═══════════════════════════════════════════════════════════════
{
  "name": "@aizquad/terminal-bridge",
  "version": "1.0.0",
  "description": "Sovereign Lab TypeScript bridge for FC_FLOW MESH",
  "main": "dist/TerminalBridge.js",
  "types": "dist/TerminalBridge.d.ts",
  "scripts": {
    "build":       "tsc",
    "test":        "jest --coverage",
    "test:watch":  "jest --watch",
    "lint":        "eslint src/**/*.ts",
    "typecheck":   "tsc --noEmit",
    "clean":       "rm -rf dist coverage"
  },
  "devDependencies": {
    "@types/jest":       "^29.5.0",
    "@types/node":       "^20.0.0",
    "jest":              "^29.5.0",
    "ts-jest":           "^29.1.0",
    "typescript":        "^5.0.0"
  },
  "jest": {
    "preset":              "ts-jest",
    "testEnvironment":     "node",
    "testMatch":           ["**/tests/ts/**/*.test.ts"],
    "coverageDirectory":   "coverage",
    "coverageThreshold": {
      "global": {
        "branches":   80,
        "functions":  80,
        "lines":      80,
        "statements": 80
      }
    }
  }
}
