install: ## Install all dependencies
	@echo "$(CYAN)$(BOLD)Installing dependencies...$(RESET)"
	@if [ ! -d "$(VENV_DIR)" ]; then \
		echo "  $(GREEN)Creating virtual environment...$(RESET)"; \
		$(PYTHON) -m venv $(VENV_DIR); \
	fi
	@echo "  $(GREEN)Installing Python packages...$(RESET)"
	@$(VENV_PIP) install --upgrade pip > /dev/null 2>&1
	@if [ -f requirements.txt ]; then \
		$(VENV_PIP) install -r requirements.txt > /dev/null 2>&1; \
	fi
	@$(VENV_PIP) install black ruff mypy pytest > /dev/null 2>&1
	@echo "  $(GREEN)✓ Dependencies installed$(RESET)"
	@echo ""
	@echo "  $(DIM)Activate venv: source .venv/bin/activate$(RESET)"
	@echo ""

# ───────────────────────────────────────────────────────────────
#  PHASE 1 — LOCK
# ───────────────────────────────────────────────────────────────

