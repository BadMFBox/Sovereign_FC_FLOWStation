	@echo "  $(GREEN)✓ Workspace ready: forge/active/$(ROOM)/$(RESET)"
	@echo ""
	@echo "  $(DIM)Write your code in: forge/active/$(ROOM)/$(RESET)"
	@echo "  $(DIM)When done: make lock ROOM=$(ROOM) V=v1$(RESET)"
	@echo ""

lock: ## Lock active work into immutable snapshot
	@echo ""
	@$(PYTHON) flow_lock.py lock $(ROOM) $(VERSION)
	@echo ""

