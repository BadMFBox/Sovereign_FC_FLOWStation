.PHONY: fluid-scan
fluid-scan: ## Scan room and label what fluid layer sees
	@$(NODE) -e "
	  const { FluidScanner }  = require('./FluidScanner');
	  const { FluidDisplay }  = require('./FluidDisplay');
	  const { getBridge }     = require('./TerminalBridgeFactory');
	  const bridge = getBridge('.');
	  const scanner = new FluidScanner(bridge);
	  const scan = scanner.scan('forge/active/$(ROOM)', '$(ROOM)');
	  FluidDisplay.render(scan);
	"

.PHONY: fluid-status
fluid-status: ## Compact fluid status for all rooms
	@$(NODE) -e "
	  const { FluidScanner } = require('./FluidScanner');
	  const { FluidDisplay } = require('./FluidDisplay');
	  const { getBridge }    = require('./TerminalBridgeFactory');
	  const bridge = getBridge('.');
	  const scanner = new FluidScanner(bridge);
	  const scan = scanner.scan('forge/active/$(ROOM)', '$(ROOM)');
	  FluidDisplay.renderCompact(scan);
	"

