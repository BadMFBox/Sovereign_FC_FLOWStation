.PHONY: ai-chat
ai-chat: ## Ask AI about a room (requires ROOM=<name> QUERY="<question>")
	@$(PYTHON) -c "from ai_agent import AIAgent; \
	               from terminal_bridge import TerminalBridge; \
	               bridge = TerminalBridge('.'); \
	               agent = AIAgent(bridge, '$(OPENAI_KEY)'); \
	               resp = agent.ask({'room': '$(ROOM)', 'query': '$(QUERY)'}); \
	               print(resp['answer'])"

.PHONY: ai-status
ai-status: ## Show current AI access for all rooms
	@$(PYTHON) -c "from terminal_bridge import TerminalBridge; \
	               bridge = TerminalBridge('.'); \
	               access = bridge.getAIAccessMap(); \
	               for room, rec in access.items(): \
	                   if rec['active']: \
	                       print(f'{room}: {rec[\"level\"]} (granted {rec[\"grantedAt\"]})')"

# Usage:
# make ai-chat ROOM=room-payments QUERY="What does the refund function do?"
# make ai-status
