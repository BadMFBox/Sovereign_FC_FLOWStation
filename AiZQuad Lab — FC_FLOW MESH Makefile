# ───────────────────────────────────────────────────────────────
#  C++ BUILD
# ───────────────────────────────────────────────────────────────

cpp-build: ## Build C++ components
	@echo ""
	@echo "$(CYAN)$(BOLD)Building C++ components...$(RESET)"
	@mkdir -p $(CPP_BUILD)
	@cd $(CPP_BUILD) && \
		$(CMAKE) -DCMAKE_BUILD_TYPE=$(BUILD_TYPE) ../.. && \
		$(CMAKE) --build . --config $(BUILD_TYPE)
	@echo "  $(GREEN)✓ C++ build complete$(RESET)"
	@echo ""

cpp-test: cpp-build ## Run C++ tests
	@echo ""
	@echo "$(CYAN)$(BOLD)Running C++ tests...$(RESET)"
	@cd $(CPP_BUILD) && ctest --output-on-failure
	@echo ""

cpp-clean: ## Clean C++ build
	@echo "  $(YELLOW)Cleaning C++ build...$(RESET)"
	@rm -rf $(CPP_BUILD)
	@echo "  $(GREEN)✓ C++ build cleaned$(RESET)"

# ───────────────────────────────────────────────────────────────
#  QUALITY CHECKS
# ───────────────────────────────────────────────────────────────

test: ## Run all Python tests
	@echo ""
	@echo "$(CYAN)$(BOLD)Running tests...$(RESET)"
	@if [ -d "$(VENV_DIR)" ]; then \
		$(VENV_PYTHON) -m pytest tests/ -v; \
	else \
		$(PYTHON) -m pytest tests/ -v; \
	fi
	@echo ""

lint: ## Lint Python code with ruff
	@echo ""
	@echo "$(CYAN)$(BOLD)Linting code...$(RESET)"
	@if [ -d "$(VENV_DIR)" ]; then \
		$(VENV_BIN)/ruff check *.py; \
	else \
		ruff check *.py; \
	fi
	@echo "  $(GREEN)✓ Lint complete$(RESET)"
	@echo ""

format: ## Format code with black
	@echo ""
	@echo "$(CYAN)$(BOLD)Formatting code...$(RESET)"
	@if [ -d "$(VENV_DIR)" ]; then \
		$(VENV_BIN)/black *.py; \
	else \
		black *.py; \
	fi
	@echo "  $(GREEN)✓ Format complete$(RESET)"
	@echo ""

check: ## Type check with mypy
	@echo ""
	@echo "$(CYAN)$(BOLD)Type checking...$(RESET)"
	@if [ -d "$(VENV_DIR)" ]; then \
		$(VENV_BIN)/mypy *.py --ignore-missing-imports; \
	else \
		mypy *.py --ignore-missing-imports; \
	fi
	@echo ""

