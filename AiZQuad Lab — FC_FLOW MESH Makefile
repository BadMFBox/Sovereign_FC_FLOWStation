	@echo "$(CYAN)$(BOLD)╔═══════════════════════════════════════════╗$(RESET)"
	@echo "$(CYAN)$(BOLD)║  PHASE 1 — FORGE                         ║$(RESET)"
	@echo "$(CYAN)$(BOLD)╚═══════════════════════════════════════════╝$(RESET)"
