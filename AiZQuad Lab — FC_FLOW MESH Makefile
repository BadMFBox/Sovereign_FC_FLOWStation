	@$(PYTHON) flow_integrate.py status
	@echo ""

list: ## List all rooms
	@echo ""
	@echo "$(CYAN)$(BOLD)All Rooms$(RESET)"
	@echo ""
	@echo "$(BOLD)Locked:$(RESET)"
	@if [ -d "forge/locked" ]; then \
		ls -1 forge/locked/*.lock.json 2>/dev/null | \
		sed 's|forge/locked/||g' | sed 's|.lock.json||g' | \
		awk '{print "  🔒 " $$0}' || echo "  $(DIM)none$(RESET)"; \
	else \
		echo "  $(DIM)none$(RESET)"; \
	fi
	@echo ""
	@echo "$(BOLD)Split:$(RESET)"
	@if [ -d "splitter/output" ]; then \
		ls -d splitter/output/*/ 2>/dev/null | \
		sed 's|splitter/output/||g' | sed 's|/||g' | \
		awk '{print "  📦 " $$0}' || echo "  $(DIM)none$(RESET)"; \
	else \
		echo "  $(DIM)none$(RESET)"; \
	fi
	@echo ""
	@echo "$(BOLD)Sorted:$(RESET)"
	@if [ -d "sorter/output" ]; then \
		ls -d sorter/output/*/ 2>/dev/null | \
		sed 's|sorter/output/||g' | sed 's|/||g' | \
		awk '{print "  🗂  " $$0}' || echo "  $(DIM)none$(RESET)"; \
	else \
		echo "  $(DIM)none$(RESET)"; \
	fi
	@echo ""
	@echo "$(BOLD)Integrated:$(RESET)"
	@if [ -d "integration/output/mesh" ]; then \
		ls -d integration/output/mesh/*/ 2>/dev/null | \
		sed 's|integration/output/mesh/||g' | sed 's|/||g' | \
		awk '{print "  🔌 " $$0}' || echo "  $(DIM)none$(RESET)"; \
	else \
		echo "  $(DIM)none$(RESET)"; \
	fi
	@echo ""

clean: ## Clean all output directories
	@echo ""
	@echo "$(YELLOW)$(BOLD)Cleaning outputs...$(RESET)"
	@rm -rf splitter/output/*
	@rm -rf sorter/output/*
	@rm -rf sorter/input/*
	@rm -rf integration/merge/*
	@rm -rf integration/input/*
	@rm -rf $(BUILD_DIR)
	@echo "  $(GREEN)✓ Cleaned$(RESET)"
	@echo ""

reset: clean ## Reset entire pipeline (WARNING: deletes everything)
	@echo ""
	@echo "$(RED)$(BOLD)⚠  RESET PIPELINE$(RESET)"
	@echo "  $(YELLOW)This will DELETE:$(RESET)"
	@echo "    - All locked versions"
	@echo "    - All split modules"
	@echo "    - All sorted files"
	@echo "    - All integrated mesh"
	@echo "    - All logic locks"
	@echo "    - Session data"
	@echo ""
	@read -p "  Type 'RESET' to confirm: " confirm; \
	if [ "$$confirm" = "RESET" ]; then \
		echo "  $(RED)Resetting...$(RESET)"; \
		rm -rf forge/locked/*; \
		rm -rf forge/versions/*; \
		rm -rf splitter/output/*; \
		rm -rf sorter/output/*; \
		rm -rf integration/merge/*; \
		rm -rf integration/output/*; \
		rm -rf integration/logic_locks/*; \
		rm -rf shared/.session; \
		rm -rf $(BUILD_DIR); \
		echo "  $(GREEN)✓ Pipeline reset$(RESET)"; \
	else \
		echo "  $(YELLOW)Aborted$(RESET)"; \
	fi
	@echo ""

