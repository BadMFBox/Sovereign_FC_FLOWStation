	@tar -czf dist/mesh-$(shell date +%Y%m%d-%H%M%S).tar.gz \
		integration/output/mesh/ \
		integration/logic_locks/ \
		shared/pipeline_state.json
	@echo "  $(GREEN)✓ Package created in dist/$(RESET)"
	@echo ""

release: test lint verify package ## Create release (test + lint + verify + package)
