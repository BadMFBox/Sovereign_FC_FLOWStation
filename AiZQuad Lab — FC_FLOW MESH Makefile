.PHONY: fluid-dialog
fluid-dialog: ## Start fluid dialog for a room (ROOM=<name> VERSION=<version> RESUME=<true|false>)
	@$(NODE) -e " \
	  const { FluidDialog }  = require('./dist/FluidDialog'); \
	  const { getBridge }    = require('./dist/TerminalBridgeFactory'); \
	  const bridge = getBridge('.'); \
	  const dialog = new FluidDialog(bridge, { \
	    room:    '$(ROOM)', \
	    version: '$(VERSION)', \
	    resume:  $(RESUME) === 'true' \
	  }); \
	  dialog.start().then(plan => { \
	    if (plan) { \
	      console.log('\n✅ Dialog complete. Plan saved.'); \
	      process.exit(0); \
	    } else { \
	      console.log('\n⚠  Dialog ended without completing plan.'); \
	      process.exit(1); \
	    } \
	  }).catch(err => { \
	    console.error('Dialog error:', err.message); \
	    process.exit(1); \
	  }); \
	"

.PHONY: fluid-resume
fluid-resume: ## Resume a paused dialog (ROOM=<name>)
	@$(MAKE) fluid-dialog ROOM=$(ROOM) VERSION=auto RESUME=true

.PHONY: fluid-plans
fluid-plans: ## List all saved dialog plans
	@echo ""
	@echo "══════════════════════════════════════════════════════"
	@echo "  FlowStation — Saved Dialog Plans"
	@echo "══════════════════════════════════════════════════════"
	@if [ -d "shared/dialog_plans" ]; then \
	  for plan in shared/dialog_plans/*.plan.json; do \
	    if [ -f "$$plan" ]; then \
	      room=$$(basename $$plan | cut -d'-' -f1); \
	      version=$$(basename $$plan | cut -d'-' -f2); \
	      timestamp=$$(stat -f%Sm -t "%Y-%m-%d %H:%M" "$$plan" 2>/dev/null || stat -c%y "$$plan" | cut -d' ' -f1,2 | cut -d: -f1,2); \
	      echo "  $$room @ $$version  —  $$timestamp"; \
	    fi \
	  done \
	else \
	  echo "  No plans saved yet."; \
	fi
	@echo ""

.PHONY: fluid-view-plan
fluid-view-plan: ## View a saved plan (PLAN=<filename>)
	@if [ -f "shared/dialog_plans/$(PLAN)" ]; then \
	  cat shared/dialog_plans/$(PLAN) | jq .; \
	else \
	  echo "Plan not found: $(PLAN)"; \
	  echo "Run 'make fluid-plans' to see available plans."; \
	fi

